room.cloakroom.afterlook
	@if @eq(@get(item.cloak.location),hook) @then
		@nl
		@msg(message.hook_with_cloak)
	@endif
room.cloakroom.exit.east
	foyer
room.cloakroom.longdesc
	The walls of this small room were clearly once lined with hooks, though now only one remains. The exit is a door to the east.
room.cloakroom.shortdesc
	Cloakroom
room.foyer.exit.north
	@msg(message.leave_operahouse)
room.foyer.exit.out
	@msg(message.leave_operahouse)
room.foyer.exit.south
	bar
room.foyer.exit.west
	cloakroom
room.foyer.longdesc
	You are standing in a spacious hall, splendidly decorated in red and gold, with glittering chandeliers overhead. The entrance from the street is to the north, and there are doorways south and west.
room.foyer.shortdesc
	Foyer of the Opera House
script.bar_cant_go
	@if @dark @then
		@msg(message.movedark)
		@addto(value.scuffed,1)
	@else
		@msg(message.cant_go)
	@endif
script.restart
	@set(__yorn,@getinchannel)
	@if @true(@get(__yorn)) @then
		@setoutchannel("#RESTART;")
		@setoutchannel("@msg(message.restarting) @nl")
		@setoutchannel("@script(system.intro)")
	@elseif @false(@get(__yorn)) @then
		@msg(message.ok)
	@else
		@msg(message.yorn_error)
		@setoutchannel("#ASK;")
		@setoutchannel("@script(script.restart))")
	@endif
script.restore_slot
	@comment("value.slot already has a valid value")
	@set(__yorn,@getinchannel)
	@if @true(@get(__yorn)) @then
		@setoutchannel("#RESTORENAME;",@get(value.slot))
		@setoutchannel("@msg(message.restore_complete) @nl")
		@setoutchannel("@lookfull")
	@else
		@msg(message.ok)
		@set(value.slot,null)
	@endif
script.restore_slot_check
	@comment("value.slot already has slot number")
	@if @isnumber(@get(value.slot)) @and @ge(@get(value.slot),1) @and @le(@get(value.slot),5) @then
		@setoutchannel("#EXISTSNAME;",@get(value.slot))
		@setoutchannel("@script(script.restore_slot_check_file)")
	@else
		@msg(message.invalid_save_slot)
		@set(value.slot,null)
	@endif
script.restore_slot_check_file
	@set(__exists,@getinchannel)
	@if @true(@get(__exists)) @then
		@msg(message.askrestore)
		@setoutchannel("#ASK;")
		@setoutchannel("@script(script.restore_slot)")
	@else
		@set(value.slot,null)
		@msg(message.savefile_not_found)
	@endif
script.restore_slot_get
	@set(value.slot,@getinchannel)
	@script(script.restore_slot_check)
script.save_slot
	@set(value.slot,@getinchannel)
	@if @isnumber(@get(value.slot)) @and @ge(@get(value.slot),1) @and @le(@get(value.slot),5) @then
		@setoutchannel("#SAVENAME;",@get(value.slot))
		@setoutchannel("@msg(message.save_complete)")
	@else
		@msg(message.save_slot_number)
		@setoutchannel("#ASK;")
		@setoutchannel("@script(script.save_slot)")
	@endif
