// CloakOfDarkness.grif - GRIF format
@addscore(x)
	@if @ne($x,0) @then
		@addto(value.score,$x)
		@if @eq($x,1) @then
			@set(__s,"")
		@else
			@set(__s,"s")
		@endif
		@write(@format(@get(message.scoreup),$x,@get(__s)))
		@nl
	@endif
@carry(x)
	@if @eq(@getvalue(item.$x.location),@inv) @then
		@write(true)
	@else
		@write(false)
	@endif
@dark
	@if @not @isroom(bar) @then
		@write(false)
	@elseif @herecarry(cloak) @then
		@write(true)
	@else
		@write(false)
	@endif
@godir(x)
	@debug(@concat("going to room.",@room,".exit.",$x))
	@set(__key,@concat("room.",@room,".exit.",$x))
	@if @not @exists(@get(__key)) @then
		@msg(message.cant_go)
	@elseif @isscript(@get(__key)) @then
		@script(@get(__key))
	@else
		@goto(@get(@get(__key)))
	@endif
@goto(x)
	@debug("goto $x")
	@if @null(@get(room.$x.longdesc)) @and @null(@get(room.$x.shortdesc)) @then
		@writeline("Invalid room: $x")
	@else
		@set(value.room,$x)
		@look
	@endif
@here(x)
	@if @eq(@getvalue(item.$x.location),@room) @then
		@write(true)
	@else
		@write(false)
	@endif
@herecarry(x)
	@if @here($x) @or @carry($x) @then
		@write(true)
	@else
		@write(false)
	@endif
@herechild(x)
	@set(__here,false)
	@foreachkey(y,"item.",".location")
		@if @eq(@getvalue(item.$y.location),@room) @and @eq(@getvalue(item.$x.location),$y) @then
			@set(__here,true)
		@endif
	@endforeachkey
	@write(@get(__here))
@inv
	inventory
@isroom(x)
	@eq(@room,$x)
@look
	@if @dark @then
		@msg(message.too_dark)
	@else
		@script(@concat("room.",@room,".beforelook"))
		@msg(@concat("room.",@room,".shortdesc"))
		@if @false(@get(@concat("room.",@room,".visited"))) @or @true(@get(value.fulllook)) @then
			@nl
			@msg(@concat("room.",@room,".longdesc"))
		@endif
		@set(@concat("room.",@room,".visited"),true)
		@set(value.fulllook,false)
		@script(@concat("room.",@room,".afterlook"))
		@foreachkey(x,"item.",".location")
			@if @here($x) @and @not @true(@get(item.$x.scenery)) @then
				@nl
				@msg(item.$x.longdesc)
			@endif
		@endforeachkey
	@endif
@lookfull
	@set(value.fulllook,true)
	@look
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
adjective.black
	cloak
adjective.brass
	hook
adjective.dark
	cloak
adjective.handsome
	cloak
adjective.satin
	cloak
adjective.small
	hook
adjective.velvet
	cloak
command.down
	@godir(down)
command.drop
	@msg(message.drop_what)
command.drop.*
	@if @carry(@get(input.noun)) @then
		@if @isroom(bar) @and @dark @then
			@msg(message.otherdark)
		@else
			@set(@concat("item.",@get(input.noun),".location"),@room)
			@msg(message.ok)
			@script(@concat("item.",@get(input.noun),".afterdrop"))
		@endif
	@else
		@msg(message.dont_have)
	@endif
command.east
	@godir(east)
command.examine
	@msg(message.examine_what)
command.examine.cloak
	@if @herecarry(cloak) @or @herechild(cloak) @then
		@write("A ")
		@msg(item.cloak.description)
	@else
		@msg(message.dont_see)
	@endif
command.examine.hook
	@msg(item.hook.examine)
command.examine.message
	@script(command.read.message)
command.go.*
	@if @null(@get(input.noun)) @then
		@msg(system.dont_understand_that)
	@else
		@godir(@get(input.noun))
	@endif
command.hang
	@msg(message.hang_what)
command.hang.cloak
	@if @here(hook) @and @herecarry(cloak) @then
		@set(item.cloak.location,hook)
		@msg(message.cloak_hanging)
		@if @ne(@get(value.cloakscore),0) @then
			@nl
			@addscore(@get(value.cloakscore))
			@set(value.cloakscore,0)
		@endif
	@elseif @herechild(cloak) @then
		@msg(message.already_hanging)
	@else
		@msg(message.dont_see)
	@endif
command.hang.cloak.on.hook
	@script(command.hang.cloak)
command.help
	@msg(message.help)
command.inventory
	@set(__count,0)
	@foreachkey(x,"item.",".location")
		@if @carry($x) @then
			@if @eq(@get(__count),0) @then
				@msg(message.carrying)
			@endif
			@addto(__count,1)
			@msg(item.$x.shortdesc)
		@endif
	@endforeachkey
	@if @eq(@get(__count),0) @then
		@msg(message.inv_empty)
	@endif
command.look
	@lookfull
command.look.*
	@script(@concat("command.examine.",@get(input.noun)))
command.look.at.*
	@script(@concat("command.examine.",@get(input.object)))
command.look.at.room
	@lookfull
command.look.room
	@lookfull
command.north
	@godir(north)
command.out
	@godir(out)
command.quit
	@script(command.score)
	@quit
command.read
	@msg(message.read_what)
command.read.message
	@if @isroom(bar) @then
		@if @dark @then
			@msg(message.otherdark)
			@addto(value.scuffed,1)
		@else
			@if @lt(@get(value.scuffed),2) @then
				@write(@get(message.readable))
				@write(".")
				@sleep(750)
				@write(".")
				@sleep(750)
				@write(".")
				@sleep(750)
				@nl
				@nl
				@msg(message.you_won)
				@nl
				@addscore(@get(value.messagescore))
				@set(value.messagescore,0)
			@else
				@write(@get(message.unreadable))
				@write(".")
				@sleep(750)
				@write(".")
				@sleep(750)
				@write(".")
				@sleep(750)
				@nl
				@nl
				@msg(message.you_lost)
			@endif
			@nl
			@script(command.score)
			@quit
		@endif
	@else
		@msg(message.dont_see)
	@endif
command.restart
	@msg(message.askrestart)
	@setoutchannel("#ASK;")
	@setoutchannel("@script(script.restart)")
command.restore
	@msg(message.save_slot_number)
	@setoutchannel("#ASK;")
	@setoutchannel("@script(script.restore_slot_get)")
command.restore.?
	@msg(message.invalid_save_slot)
command.restore.#
	@set(value.slot,@get(input.nounword))
	@if @isnumber(@get(value.slot)) @and @ge(@get(value.slot),1) @and @le(@get(value.slot),5) @then
		@script(script.restore_slot_check)
	@else
		@msg(message.invalid_save_slot)
		@set(value.slot,null)
	@endif
command.save
	@msg(message.save_slot_number)
	@setoutchannel("#ASK;")
	@setoutchannel("@script(script.save_slot)")
command.save.#
	@set(value.slot,@get(input.nounword))
	@if @isnumber(@get(value.slot)) @and @ge(@get(value.slot),1) @and @le(@get(value.slot),5) @then
		@setoutchannel("#SAVENAME;",@get(value.slot))
		@setoutchannel("@msg(message.save_complete)")
	@else
		@msg(message.save_slot_number)
		@setoutchannel("#ASK;")
		@setoutchannel("@script(script.save_slot)")
	@endif
command.score
	@writeline(@format(@get(message.score),@get(value.score),@get(value.maxscore)))
command.south
	@godir(south)
command.take
	@msg(message.take_what)
command.take.*
	@if @dark @then
		@msg(message.too_dark)
	@elseif @here(@get(input.noun)) @or @herechild(@get(input.noun)) @then
		@if @true(@get(@concat("item.",@get(input.noun),".scenery"))) @then
			@msg(message.cant_take)
		@else
			@set(@concat("item.",@get(input.noun),".location"),@inv)
			@msg(message.ok)
			@script(@concat("item.",@get(input.noun),".aftertake"))
		@endif
	@elseif @carry(@get(input.noun)) @then
		@msg(message.already_carrying)
	@else
		@msg(message.dont_see)
	@endif
command.take.cloak.from.hook
	@if @here(hook) @and @herechild(cloak) @then
		@set(item.cloak.location,@inv)
		@msg(message.ok)
	@else
		@msg(message.dont_see)
	@endif
command.up
	@godir(up)
command.use.hook
	@script(command.hang.cloak)
command.version
	@msg(system.version)
command.west
	@godir(west)
